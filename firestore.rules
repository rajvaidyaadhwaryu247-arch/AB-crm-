rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // CRM collections allowed for unauthenticated single-user personal use
    match /clients/{clientId} {
      allow read, write: if true;
    }

    match /leads/{leadId} {
      allow read, write: if true;
    }

    match /tasks/{taskId} {
      allow read, write: if true;
    }

    match /activities/{activityId} {
      allow read, write: if true;
    }

    match /followups/{followupId} {
      allow read, write: if true;
    }

    match /reminders/{reminderId} {
      allow read, write: if true;
    }

    match /telegramSettings/{userId} {
      allow read, write: if true;
    }

    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    match /pari_reminders/{id} {
      allow read, write: if true;
    }

    match /pari_verifications/{id} {
      allow read, write: if true;
    }

    match /pari_data_center/{id} {
      allow read, write: if true;
    }

    match /brandSettings/{id} {
      allow read, write: if true;
    }
  }
}
